# Ghostty Configuration
# Docs:   https://ghostty.org/docs/config
# Themes: ghostty +list-themes
# All options: ghostty +show-config --default --docs

# ─── Appearance ──────────────────────────────────────────────────────────────

theme                    = Everforest Dark Hard
font-family              = JetBrainsMono Nerd Font
font-size                = 18
cursor-style             = block
cursor-style-blink       = false
window-padding-x         = 6
window-padding-y         = 6
maximize = true

# ─── Split Navigation (alt+hjkl — mirrors ctrl+w hjkl in nvim) ───────────────

keybind = alt+h=goto_split:left
keybind = alt+j=goto_split:bottom
keybind = alt+k=goto_split:top
keybind = alt+l=goto_split:right

# ─── New Splits ──────────────────────────────────────────────────────────────

keybind = alt+v=new_split:right
keybind = alt+s=new_split:down

# ─── Resize Splits (ctrl+alt+hjkl) ───────────────────────────────────────────

keybind = ctrl+alt+h=resize_split:left,50
keybind = ctrl+alt+j=resize_split:down,50
keybind = ctrl+alt+k=resize_split:up,50
keybind = ctrl+alt+l=resize_split:right,50

# ─── Tabs (ctrl+shift+h/l — mirrors <S-h>/<S-l> buffer cycling in nvim) ──────

keybind = ctrl+t=new_tab
keybind = ctrl+shift+x=close_tab
keybind = ctrl+shift+l=next_tab
keybind = ctrl+shift+h=previous_tab

# ─── Miscellaneous ───────────────────────────────────────────────────────────

keybind = ctrl+shift+period=open_config
keybind = ctrl+shift+slash=toggle_window_decorations
